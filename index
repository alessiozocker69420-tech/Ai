<!DOCTYPE html>
<html>
<head>
    <title>Mein AI Chat</title>
    <style>
        /* Das hier macht das Design! */
        body { background: #1a1a1a; color: white; font-family: sans-serif; display: flex; justify-content: center; padding: 20px; }
        .chat-box { width: 400px; height: 500px; background: #2a2a2a; border-radius: 15px; display: flex; flex-direction: column; overflow: hidden; border: 1px solid #444; }
        #messages { flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
        
        /* Sprechblasen */
        .msg { padding: 10px; border-radius: 10px; max-width: 80%; font-size: 14px; }
        .user { align-self: flex-end; background: #00ffcc; color: black; }
        .bot { align-self: flex-start; background: #444; color: white; }

        .input-area { padding: 10px; background: #333; display: flex; gap: 5px; }
        input { flex: 1; padding: 8px; border-radius: 5px; border: none; }
        button { background: #00ffcc; border: none; padding: 8px; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>

<div class="chat-box">
    <div id="messages">
        <div class="msg bot">Hi! Ich bin dein neuer Chatbot.</div>
    </div>
    <div class="input-area">
        <input type="text" id="userInput" placeholder="Schreib was...">
        <button onclick="send()">Senden</button>
    </div>
</div>

<script>
    async function send() {
        const input = document.getElementById('userInput');
        const msgDiv = document.getElementById('messages');
        const text = input.value;
        if(!text) return;

        // User Nachricht anzeigen
        msgDiv.innerHTML += `<div class="msg user">${text}</div>`;
        input.value = "";

        // HIER kommt dein Key rein (nur zum lokalen Testen!)
        const apiKey = "DEIN_KEY_HIER";

        try {
            const response = await fetch("https://openai.com", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": `Bearer ${apiKey}`
                },
                body: JSON.stringify({
                    model: "gpt-3.5-turbo",
                    messages: [{role: "user", content: text}]
                })
            });
            const data = await response.json();
            const reply = data.choices[0].message.content;
            
            // Bot Antwort anzeigen
            msgDiv.innerHTML += `<div class="msg bot">${reply}</div>`;
        } catch (e) {
            msgDiv.innerHTML += `<div class="msg bot" style="color:red">Fehler!</div>`;
        }
        msgDiv.scrollTop = msgDiv.scrollHeight;
    }
</script>

</body>
</html>
